# =============================================================================
# UnifiedOps v2 Listener Env Configuration (BCP + UAT)
# Location: /etc/unifiedops/listener-brcd-bcp-uat.env
# =============================================================================

# Main InfluxDB Settings (runs natively as a service on the target VM)
HITRACK_INFLUX_URL=http://127.0.0.1:8086
HITRACK_INFLUX_TOKEN=YOUR_INFLUX_TOKEN_HERE
HITRACK_INFLUX_ORG=HDFC
HITRACK_INFLUX_BUCKET=SYSLOG_BRCD_BCP_UAT_Bucket

# syslog health check/reports write-routing (writes non-alert messages here)
# If reports share same InfluxDB instance, configure URL/TOKEN to match above.
HITRACK_INFLUX_REPORT_URL=http://127.0.0.1:8086
HITRACK_INFLUX_REPORT_TOKEN=YOUR_INFLUX_TOKEN_HERE
HITRACK_INFLUX_REPORT_BUCKET=unifiedops-influx-health-report-bcp

# Listener settings
HITRACK_LISTEN_HOST=0.0.0.0
HITRACK_LISTEN_PORT=515

# Workers & Batch settings
HITRACK_WORKER_THREADS=16
HITRACK_WRITE_BATCH=true
HITRACK_WRITE_BATCH_SIZE=200
HITRACK_WRITE_FLUSH_MS=1000
HITRACK_WRITE_RETRY_MS=1000

# Dev/Test Mode spoofing (disable in production)
HITRACK_TEST_MODE=false
