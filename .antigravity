{
  "defaultModel": "coder-heavy",
  "autoCommit": true,
  "commitAfterTask": true,
  "creditConservation": {
    "priorityLadder": [
      "local-ollama",
      "nvidia-nim",
      "ollama-cloud",
      "free-linters",
      "claude-sonnet-last-resort",
      "claude-opus-emergency-only"
    ],
    "neverAutoRun": [
      "@review",
      "@docgen"
    ]
  },
  "excludeFromContext": [
    ".git",
    ".venv",
    "UnifiedOpsv2.0.2_deploy",
    "UnifiedOpsv2.0.2_deploy.zip",
    "offline",
    "*.log",
    "*.pdf",
    ".env",
    "__pycache__"
  ],
  "contextPriority": [
    "AGENTS.md",
    "GEMINI.md",
    "server/",
    "listener/",
    "frontend/",
    "deploy/",
    "scripts/",
    "trap-sender/",
    "dev/"
  ],
  "freeLintersBeforeReview": {
    "javascript_typescript": "eslint-mcp",
    "python": "ruff-vulture-mcp",
    "note": "Always run applicable free linter before calling @review"
  }
}
